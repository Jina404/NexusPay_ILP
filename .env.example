RAFIKI_IDP_SECRET=2pEcn2kkCclbOHQiGNEwhJ0rucATZhrA807HTm2rNXE=

# M-Pesa Daraja — use /providers/mpesa/callback for payment links & gateway checkout
# Local testing: run `ngrok http 3000` and paste HTTPS URL (see scripts/ngrok-mpesa.md)
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-stk-passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-ngrok-host.ngrok-free.app/providers/mpesa/callback

# Optional — B2C / B2B / C2B / reversals (production Daraja)
# MPESA_INITIATOR_NAME=
# MPESA_SECURITY_CREDENTIAL=
# MPESA_B2C_SHORTCODE=
# MPESA_VALIDATION_URL=https://your-ngrok-host.ngrok-free.app/providers/mpesa/c2b/validation
# MPESA_CONFIRMATION_URL=https://your-ngrok-host.ngrok-free.app/providers/mpesa/c2b/confirmation
# MPESA_B2C_RESULT_URL=https://your-ngrok-host.ngrok-free.app/providers/mpesa/b2c/result
# MPESA_B2B_RESULT_URL=https://your-ngrok-host.ngrok-free.app/providers/mpesa/b2b/result
# MPESA_REVERSAL_RESULT_URL=https://your-ngrok-host.ngrok-free.app/providers/mpesa/reversal/result

# Exchange rates served to Rafiki
EXCHANGE_RATES={"KES":{"UGX":28.5,"TZS":18.2,"USD":0.0077},"UGX":{"KES":0.035},"TZS":{"KES":0.055}}

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000
# Optional: logo in Supabase Storage (bucket/files or brand-assets)
# NEXT_PUBLIC_BRAND_LOGO_URL=https://psqjqxsxjeiduuyhkcgt.supabase.co/storage/v1/object/public/files/logo.png

# Supabase Auth (Dashboard → Authentication → URL Configuration)
# Site URL: http://localhost:3015
# Redirect URLs: http://localhost:3015/auth/callback
# Run SQL migrations in supabase/migrations/ via SQL Editor (in order)

# STK timeout (ms)
STK_TIMEOUT_MS=120000
