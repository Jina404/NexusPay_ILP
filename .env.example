# NexusPay environment (copy to .env and fill in values)

# API
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_PUBLIC_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Rafiki Admin API
RAFIKI_GRAPHQL_URL=http://localhost:3001/graphql
RAFIKI_TENANT_ID=438fa74a-fa7d-4317-9ced-dde32ece1787
RAFIKI_API_SECRET=iyIgCprjb9uL8wFckR+pLEkJWMB7FJhgkvqhTQR/964=
RAFIKI_SIGNATURE_VERSION=1
RAFIKI_WEBHOOK_SECRET=iyIgCprjb9uL8wFckR+pLEkJWMB7FJhgkvqhTQR/964=
